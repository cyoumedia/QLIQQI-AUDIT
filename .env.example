# Server-side only — never commit .env.local
# Copy to .env.local and fill in values

# Google PageSpeed Insights — REQUIRED for Lighthouse scores in practice
# (shared unauthenticated quota is exhausted quickly; returns 429 without your own key)
# Enable "PageSpeed Insights API" in Google Cloud → Credentials → API key
GOOGLE_PAGESPEED_API_KEY=

# AI providers (required for full audit)
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=

# Crawl settings
CRAWL_CONCURRENCY=8

# Retry Cloudflare/WAF-blocked pages via Playwright/Chrome (requires Google Chrome or Playwright Chromium).
# Runs headless by default; escalates to an off-screen headed window only when Cloudflare blocks headless.
CRAWL_BROWSER_FALLBACK=true

# Show the Chrome window during Cloudflare bypass (debug only — leave false for normal use)
CRAWL_BROWSER_HEADED=false

# Re-fetch JS shell pages (blocked/thin static HTML) via headless browser for richer AI analysis
CRAWL_BROWSER_SHELL_MAX_PAGES=10
CRAWL_BROWSER_SHELL_MIN_HTML=500
CRAWL_BROWSER_SHELL_MIN_WORDS=30

# Retry failed fetches; expand crawl via internal links found on fetched pages
CRAWL_FETCH_RETRY_MAX=8
CRAWL_LINK_EXPANSION_MAX=40

# Map-reduce AI summary when many pages are analyzed in depth
AI_MAP_REDUCE_THRESHOLD=15
AI_MAP_REDUCE_BATCH_SIZE=8

# PSI: number of representative pages to sample site-wide (not every crawled URL)
PSI_SAMPLE_SIZE=16

# Max parallel PSI API calls (avoids Google quota spikes)
PSI_CONCURRENCY=4

# Max failing audits per category in seed URL Lighthouse diagnostics (reporting only)
PSI_DIAGNOSTICS_MAX=20

# Cap pages sent to AI prompts; full discovery still runs without limit
AI_SUMMARY_PAGE_LIMIT=50
AI_MAX_CHARS_PER_PAGE=4000

# Max nested sitemap index recursion depth
MAX_SITEMAP_DEPTH=3

# Crawl budget — disabled in v1; enable for free-tier / paid tiers later
CRAWL_BUDGET_ENABLED=false
CRAWL_BUDGET_MS=480000

# Rate limiting
RATE_LIMIT_AUDITS_PER_HOUR=3

# Dev-only UI and report extras (crawl JSON download, per-provider AI scores).
# Defaults to true when running npm run dev. Set to false to preview the production client locally.
NEXT_PUBLIC_QLIQQI_DEV_FEATURES=false
  